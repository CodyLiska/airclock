import json
import subprocess
import time
from datetime import datetime, timedelta
from pathlib import Path
from threading import Thread, Lock

from gpiozero import RotaryEncoder, Button
from luma.core.interface.serial import spi
from luma.lcd.device import ili9341
from luma.core.render import canvas
from PIL import ImageFont

from sensirion_i2c_driver import LinuxI2cTransceiver, I2cConnection
from sensirion_i2c_scd import Scd4xI2cDevice

# ---------- Paths ----------
CONFIG_PATH = Path("/home/hxchillbilly/airclock/config.json")

# ---------- Display ----------
serial = spi(port=0, device=0, gpio_DC=25, gpio_RST=24)
device = ili9341(serial, width=320, height=240, rotate=1)
font = ImageFont.load_default()

# ---------- Audio ----------
AUDIO_DEVICE = "plughw:2,0"
SOUND_FILE = "/home/hxchillbilly/airclock/sounds/beep_short.wav"

alarm_thread = None
alarm_stop_requested = False

def play_sound_once():
    try:
        subprocess.run(
            ["aplay", "-D", AUDIO_DEVICE, SOUND_FILE],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
    except Exception:
        pass

def _alarm_loop():
    global alarm_stop_requested
    while not alarm_stop_requested:
        play_sound_once()
        time.sleep(1.0)

def start_alarm_sound():
    global alarm_thread, alarm_stop_requested
    if alarm_thread is None or not alarm_thread.is_alive():
        alarm_stop_requested = False
        alarm_thread = Thread(target=_alarm_loop, daemon=True)
        alarm_thread.start()

def stop_alarm_sound():
    global alarm_stop_requested
    alarm_stop_requested = True

# ---------- Inputs ----------
enc = RotaryEncoder(a=17, b=27, max_steps=0)
btn_select = Button(22, pull_up=True, bounce_time=0.08)
btn_back = Button(23, pull_up=True, bounce_time=0.08)
btn_snooze = Button(5, pull_up=True, bounce_time=0.08)

last_steps = enc.steps
last_select = False
last_back = False
last_snooze = False

# ---------- Screens ----------
SCREEN_MAIN = "main"
SCREEN_ALARM = "alarm"

current_screen = SCREEN_MAIN

# ---------- Main menu ----------
menu_items = ["Pomodoro", "Alarm", "CO2", "Settings"]
selected_index = 0

# ---------- Pomodoro ----------
pomodoro_running = False
pomodoro_duration = timedelta(minutes=25)
pomodoro_end = None
pomodoro_finished = False

# ---------- Sensor State ----------
sensor_lock = Lock()
co2_ppm = None
temp_c = None
humidity_rh = None
sensor_status = "Starting..."

# ---------- Alarm State ----------
alarm_enabled = False
alarm_hour = 7
alarm_minute = 0
alarm_ringing = False
alarm_snooze_until = None
last_alarm_trigger_minute = None

alarm_menu_items = ["Enabled", "Hour", "Minute", "Save & Exit"]
alarm_menu_index = 0
alarm_edit_mode = False

SNOOZE_MINUTES = 10

# ---------- Config ----------
def load_config():
    global alarm_enabled, alarm_hour, alarm_minute

    if not CONFIG_PATH.exists():
        return

    try:
        data = json.loads(CONFIG_PATH.read_text())
        alarm_enabled = bool(data.get("alarm_enabled", False))
        alarm_hour = int(data.get("alarm_hour", 7))
        alarm_minute = int(data.get("alarm_minute", 0))
    except Exception:
        pass

def save_config():
    data = {
        "alarm_enabled": alarm_enabled,
        "alarm_hour": alarm_hour,
        "alarm_minute": alarm_minute,
    }
    try:
        CONFIG_PATH.write_text(json.dumps(data, indent=2))
    except Exception:
        pass

# ---------- Sensor ----------
def sensor_loop():
    global co2_ppm, temp_c, humidity_rh, sensor_status

    try:
        with LinuxI2cTransceiver("/dev/i2c-1") as i2c_transceiver:
            scd4x = Scd4xI2cDevice(I2cConnection(i2c_transceiver))

            scd4x.stop_periodic_measurement()
            time.sleep(1)
            scd4x.start_periodic_measurement()
            sensor_status = "Measuring..."

            while True:
                time.sleep(5)
                co2, temperature, humidity = scd4x.read_measurement()

                with sensor_lock:
                    co2_ppm = co2.co2
                    temp_c = temperature.degrees_celsius
                    humidity_rh = humidity.percent_rh
                    sensor_status = "OK"

    except Exception:
        with sensor_lock:
            sensor_status = "Sensor error"

# ---------- Helpers ----------
def clamp_index(i, n):
    return i % n

def start_pomodoro():
    global pomodoro_running, pomodoro_end, pomodoro_finished
    pomodoro_running = True
    pomodoro_finished = False
    pomodoro_end = datetime.now() + pomodoro_duration

def stop_pomodoro():
    global pomodoro_running, pomodoro_end
    pomodoro_running = False
    pomodoro_end = None

def toggle_pomodoro():
    if pomodoro_running:
        stop_pomodoro()
    else:
        start_pomodoro()

def format_remaining():
    global pomodoro_finished

    if not pomodoro_running or pomodoro_end is None:
        return "Idle"

    remaining = pomodoro_end - datetime.now()

    if remaining.total_seconds() <= 0:
        stop_pomodoro()
        if not pomodoro_finished:
            pomodoro_finished = True
            play_sound_once()
        return "Done!"

    mins = int(remaining.total_seconds() // 60)
    secs = int(remaining.total_seconds() % 60)
    return f"{mins:02d}:{secs:02d}"

def co2_status_text(value):
    if value is None:
        return "..."
    if value < 800:
        return "Good"
    if value < 1200:
        return "Moderate"
    return "Poor"

def alarm_time_string():
    return f"{alarm_hour:02d}:{alarm_minute:02d}"

def trigger_alarm():
    global alarm_ringing
    if not alarm_ringing:
        alarm_ringing = True
        start_alarm_sound()

def dismiss_alarm():
    global alarm_ringing, alarm_snooze_until
    alarm_ringing = False
    alarm_snooze_until = None
    stop_alarm_sound()

def snooze_alarm():
    global alarm_ringing, alarm_snooze_until
    alarm_ringing = False
    alarm_snooze_until = datetime.now() + timedelta(minutes=SNOOZE_MINUTES)
    stop_alarm_sound()

def check_alarm():
    global last_alarm_trigger_minute

    now = datetime.now()
    current_minute_key = now.strftime("%Y-%m-%d %H:%M")

    if alarm_ringing:
        return

    # Snooze takes precedence
    if alarm_snooze_until is not None:
        if now >= alarm_snooze_until:
            trigger_alarm()
        return

    if not alarm_enabled:
        return

    if now.hour == alarm_hour and now.minute == alarm_minute:
        if last_alarm_trigger_minute != current_minute_key:
            trigger_alarm()
            last_alarm_trigger_minute = current_minute_key

# ---------- Drawing ----------
def draw_main_screen():
    now = datetime.now()
    time_str = now.strftime("%H:%M:%S")
    date_str = now.strftime("%a %b %d")

    remaining = format_remaining()

    with sensor_lock:
        current_co2 = co2_ppm
        current_temp = temp_c
        current_humidity = humidity_rh
        current_sensor_status = sensor_status

    with canvas(device) as draw:
        draw.text((10, 10), time_str, fill="white", font=font)
        draw.text((10, 25), date_str, fill="white", font=font)

        draw.text((10, 45), f"Alarm: {'On' if alarm_enabled else 'Off'} {alarm_time_string()}", fill="white", font=font)

        if alarm_ringing:
            draw.text((10, 60), "ALARM RINGING!", fill="white", font=font)
        elif alarm_snooze_until is not None:
            draw.text((10, 60), f"Snoozed until {alarm_snooze_until.strftime('%H:%M')}", fill="white", font=font)
        else:
            draw.text((10, 60), "Alarm idle", fill="white", font=font)

        draw.text((10, 80), f"Pomodoro: {remaining}", fill="white", font=font)

        if current_co2 is None:
            draw.text((10, 105), f"CO2: {current_sensor_status}", fill="white", font=font)
        else:
            draw.text((10, 105), f"CO2: {current_co2} ppm ({co2_status_text(current_co2)})", fill="white", font=font)
            draw.text((10, 120), f"Temp: {current_temp:.1f} C", fill="white", font=font)
            draw.text((10, 135), f"Humidity: {current_humidity:.1f} %", fill="white", font=font)

        y = 165
        draw.text((10, y), "Menu:", fill="white", font=font)
        y += 15

        for i, item in enumerate(menu_items):
            prefix = ">" if i == selected_index else " "
            draw.text((10, y), f"{prefix} {item}", fill="white", font=font)
            y += 15

        draw.text((10, 220), "Select: choose | Snooze: pomo/alarm", fill="white", font=font)

def draw_alarm_screen():
    with canvas(device) as draw:
        draw.text((10, 10), "Alarm Settings", fill="white", font=font)
        draw.text((10, 25), f"Current: {alarm_time_string()}", fill="white", font=font)

        items = [
            f"Enabled: {'On' if alarm_enabled else 'Off'}",
            f"Hour: {alarm_hour:02d}",
            f"Minute: {alarm_minute:02d}",
            "Save & Exit",
        ]

        y = 60
        for i, item in enumerate(items):
            prefix = ">" if i == alarm_menu_index else " "
            suffix = " *" if alarm_edit_mode and i == alarm_menu_index else ""
            draw.text((10, y), f"{prefix} {item}{suffix}", fill="white", font=font)
            y += 20

        draw.text((10, 200), "Select: toggle/edit/save", fill="white", font=font)
        draw.text((10, 215), "Back: return | Rotate: move/change", fill="white", font=font)

def draw_screen():
    if current_screen == SCREEN_MAIN:
        draw_main_screen()
    elif current_screen == SCREEN_ALARM:
        draw_alarm_screen()

# ---------- Input handlers ----------
def handle_encoder_main():
    global selected_index, last_steps

    steps = enc.steps
    if steps != last_steps:
        if steps > last_steps:
            selected_index = clamp_index(selected_index + 1, len(menu_items))
        else:
            selected_index = clamp_index(selected_index - 1, len(menu_items))
        last_steps = steps

def handle_encoder_alarm():
    global alarm_menu_index, last_steps, alarm_hour, alarm_minute

    steps = enc.steps
    if steps == last_steps:
        return

    delta = 1 if steps > last_steps else -1

    if alarm_edit_mode:
        if alarm_menu_index == 1:
            alarm_hour = (alarm_hour + delta) % 24
        elif alarm_menu_index == 2:
            alarm_minute = (alarm_minute + delta) % 60
    else:
        alarm_menu_index = clamp_index(alarm_menu_index + delta, len(alarm_menu_items))

    last_steps = steps

def handle_buttons():
    global last_select, last_back, last_snooze
    global current_screen, alarm_edit_mode, alarm_enabled
    global pomodoro_finished, alarm_menu_index

    select_now = btn_select.is_pressed
    back_now = btn_back.is_pressed
    snooze_now = btn_snooze.is_pressed

    # Snooze button behavior always takes priority if alarm is ringing
    if snooze_now and not last_snooze:
        if alarm_ringing:
            snooze_alarm()
        elif pomodoro_finished:
            pomodoro_finished = False
        elif current_screen == SCREEN_MAIN:
            toggle_pomodoro()

    if back_now and not last_back:
        if alarm_ringing or alarm_snooze_until is not None:
            dismiss_alarm()
        elif current_screen == SCREEN_ALARM:
            if alarm_edit_mode:
                alarm_edit_mode = False
            else:
                save_config()
                current_screen = SCREEN_MAIN
    if select_now and not last_select:
        if current_screen == SCREEN_MAIN:
            selected_item = menu_items[selected_index]

            if selected_item == "Pomodoro":
                toggle_pomodoro()
                pomodoro_finished = False
            elif selected_item == "Alarm":
                current_screen = SCREEN_ALARM
                alarm_menu_index = 0
                alarm_edit_mode = False

        elif current_screen == SCREEN_ALARM:
            if alarm_menu_index == 0:
                alarm_enabled = not alarm_enabled
            elif alarm_menu_index in (1, 2):
                alarm_edit_mode = not alarm_edit_mode
            elif alarm_menu_index == 3:
                save_config()
                alarm_edit_mode = False
                current_screen = SCREEN_MAIN

    last_select = select_now
    last_back = back_now
    last_snooze = snooze_now

def handle_inputs():
    if current_screen == SCREEN_MAIN:
        handle_encoder_main()
    elif current_screen == SCREEN_ALARM:
        handle_encoder_alarm()

    handle_buttons()

# ---------- Main ----------
def main():
    global last_steps

    load_config()
    last_steps = enc.steps

    thread = Thread(target=sensor_loop, daemon=True)
    thread.start()

    while True:
        check_alarm()
        handle_inputs()
        draw_screen()
        time.sleep(0.05)

if __name__ == "__main__":
    try:
        main()
    finally:
        stop_alarm_sound()
